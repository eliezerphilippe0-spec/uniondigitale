# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# MonCash (rail de paiement MVP — voir docs/03-PAIEMENTS.md)
# NE PAS committer de vraies clés. Dépendances NatCash/BRH différées (docs §14).
MONCASH_CLIENT_ID=
MONCASH_CLIENT_SECRET=
MONCASH_MODE=sandbox

# Réconciliateur (/api/reconcile)
# - RECONCILE_SECRET : appels manuels (POST, Bearer ou x-reconcile-secret).
# - CRON_SECRET       : injecté par Vercel Cron dans l'en-tête Authorization (GET).
RECONCILE_SECRET=
CRON_SECRET=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
