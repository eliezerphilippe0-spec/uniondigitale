# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# MonCash (rail de paiement MVP — voir docs/03-PAIEMENTS.md)
# NE PAS committer de vraies clés. Dépendances NatCash/BRH différées (docs §14).
MONCASH_CLIENT_ID=
MONCASH_CLIENT_SECRET=
MONCASH_MODE=sandbox

# Rails diaspora USD (optionnels — non renseignés = rail masqué au checkout)
# Taux de conversion HTG → USD (ex. 132 = 132 HTG pour 1 USD). Requis pour
# activer Stripe ou Zelle : le montant USD est figé au checkout puis vérifié
# en base (payments.expected_usd_cents).
USD_HTG_RATE=

# Stripe (⚠️ nécessite une entité US — Haïti non supporté comme pays marchand).
# Webhook à créer côté Stripe : https://<domaine>/api/stripe/webhook,
# événement checkout.session.completed.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Zelle (flux semi-manuel : instructions + confirmation admin).
# ZELLE_RECIPIENT = e-mail/téléphone US enrôlé Zelle ; NAME = titulaire affiché.
ZELLE_RECIPIENT=
ZELLE_RECIPIENT_NAME=

# Recharge téléphonique (V-11 — revendeur Reloadly, docs/07-TOPUP.md)
# Non renseigné = service masqué (/rechaj affiche « à venir »).
RELOADLY_CLIENT_ID=
RELOADLY_CLIENT_SECRET=
RELOADLY_MODE=sandbox

# E-mails transactionnels (V-13 — livraison acheteur + notification vendeur).
# Non renseigné = aucun e-mail (le paiement fonctionne sans).
# Compte gratuit : https://resend.com (3 000 e-mails/mois).
RESEND_API_KEY=
EMAIL_FROM=Zabelie Digi <notifications@votre-domaine.com>

# Réconciliateur (/api/reconcile)
# - RECONCILE_SECRET : appels manuels (POST, Bearer ou x-reconcile-secret).
# - CRON_SECRET       : injecté par Vercel Cron dans l'en-tête Authorization (GET).
RECONCILE_SECRET=
CRON_SECRET=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
